{
  "name": "Bubble Whisper Stream",
  "short_name": "BubbleOS",
  "description": "Neurodivergent-first productivity companion with stealth wellness",
  "start_url": "/",
  "display": "standalone",
  "background_color": "hsl(var(--background))",
  "theme_color": "hsl(var(--primary))",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "categories": ["productivity", "lifestyle", "health"],
  "icons": [
    {
      "src": "/placeholder.svg",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/placeholder.svg", 
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Quick Add Task",
      "short_name": "Add Task",
      "description": "Quickly add a new task",
      "url": "/?action=add-task",
      "icons": [{ "src": "/placeholder.svg", "sizes": "96x96" }]
    },
    {
      "name": "Calendar View",
      "short_name": "Calendar",
      "description": "Open calendar view",
      "url": "/calendar",
      "icons": [{ "src": "/placeholder.svg", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+bubble",
      "url": "/?bubble=%s"
    }
  ]
}